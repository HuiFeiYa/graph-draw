{
  "name": "services",
  "version": "1.0.0",
  "description": "",
  "author": "",
  "private": true,
  "workspace": "services",
  "scripts": {
    "build": "nest build ",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start  --debug 9230 --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "electron-rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@hfdraw/elbow": "workspace:^",
    "@hfdraw/types": "workspace:^",
    "@hfdraw/utils": "workspace:^",
    "@nestjs/common": "^10.4.11",
    "@nestjs/core": "^10.4.11",
    "@nestjs/microservices": "^10.4.12",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/typeorm": "^10.0.2",
    "async-lock": "^1.4.1",
    "better-sqlite3": "11.7.2",
    "class-validator": "^0.14.1",
    "jszip": "^3.10.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.20",
    "uid": "^2.0.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@grpc/grpc-js": "^1.13.4",
    "@grpc/proto-loader": "^0.7.15",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^20.3.1",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "amqp-connection-manager": "^4.1.14",
    "amqplib": "^0.10.8",
    "electron-rebuild": "^3.2.9",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "ioredis": "^5.6.1",
    "kafkajs": "^2.2.4",
    "mqtt": "^5.13.2",
    "nats": "^2.29.3",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3",
    "webpack": "^5.96.1",
    "webpack-cli": "^5.1.4"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "volta": {
    "node": "20.18.0"
  }
}
