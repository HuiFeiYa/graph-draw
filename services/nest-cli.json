{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "watchAssets": true,
    "webpack": false
  },
  "watchOptions": {
    "watchExclude": [
      "../apps/**/*",
      "../packages/**/*",
      "../node_modules/**/*",
      "node_modules/**/*"
    ],
    "include": [
      "src/**/*.ts"
    ]
  }
}
