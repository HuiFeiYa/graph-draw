{
    "compilerOptions": {
        "module": "CommonJS",
        "target": "ES2016",
        "sourceMap": false,
        "outDir": "./dist-a",
        "rootDir": "./electron",
        "skipLibCheck": true,  // 跳过对库文件的类型检查
        "strictNullChecks": true,                // 启用严格的 null 检查
        "strictFunctionTypes": true,             // 严格检查函数参数类型
        "strictPropertyInitialization": true,   // 类的属性必须初始化
        "noImplicitThis": false,                  // 当值为 'any' 时，'this' 隐含任何类型
        "alwaysStrict": false,    
        "noImplicitAny": false,  // 允许隐式的 any 类型
    },
    "include": [
        "electron/**/*"
    ],
    "exclude": [
        "node_modules"
    ]
}
  