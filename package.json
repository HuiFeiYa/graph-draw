{
  "name": "hfdraw",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "workspaces": [
    "packages/*",
    "services",
    "apps/*"
  ],
  "scripts": {
    "start": "pnpm run client & pnpm run server",
    "client": "pnpm --filter draw-client run start",
    "server": "pnpm --filter services run start:debug",
    "b:all": "pnpm run b:elbow & pnpm run b:types",
    "b:elbow": "pnpm --filter elbow  run build",
    "b:types": "pnpm --filter types  run build",
    "i:client": "pnpm --filter draw-client install",
    "i:server": "pnpm --filter services install",
    "i:graph": "pnpm --filter graph install",
    "i": "pnpm run i:client & pnpm run i:server & pnpm run i:graph"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "volta": {
    "node": "20.18.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-vue": "^9.31.0",
    "prettier": "^3.4.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "lodash": "^4.17.21",
    "services": "^0.0.3"
  }
}
