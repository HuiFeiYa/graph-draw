{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
      "module": "ESNext",
      "target": "ES2020",
      "outDir": "dist/esm",
      "moduleResolution": "node",  // 修改为 "node"
      "resolveJsonModule": true,   // 允许解析 JSON 模块
      "esModuleInterop": true,     // 允许 CommonJS 和 ES 模块互操作
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true
    },
    "include": ["./**/*"] // 包含当前目录及其子目录下的所有文件
  }